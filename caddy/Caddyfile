# Mind Grapes — Caddy edge (issue #50, path-split for the Django cutover #95).
#
# Topology (#117 Slice E): /mcp* and the RS metadata go to the Python MCP service
# (uvicorn run_mcp, built from the web image); everything else (/, /oauth/*, the
# AS metadata, /accounts, /admin) goes to the Django web service. Caddy preserves
# the request path (Tailscale `serve` would strip the mount prefix, which is why
# the split lives here, not in tailscale/serve.json — that just roots "/" here).
#
# Two edges share one split:
#   - Tailnet (local-prod): TLS is terminated by the tailscale sidecar, which
#     forwards plain HTTP to :80 here. We force X-Forwarded-Proto=https so Django
#     sees the real external scheme (CSRF + secure cookies).
#   - Local-TLS edge: real hostname + TLS via {$BRAIN_HOSTNAME}. Used for
#     `tls internal` on localhost dev; unused in prod behind Tailscale, where
#     BRAIN_HOSTNAME defaults to localhost and public reach is Tailscale Funnel.
#
# Security headers are set by Django middleware for the human paths. The
# MCP service does not yet set app-layer security headers on /mcp + /health
# (tracked in #129); HSTS still reaches browsers domain-wide via Django.
# Caddy here is reverse-proxy + log scrubbing + body cap.

{
	# Don't expose Caddy's admin API outside the container.
	admin off

	# Bound how long a client may take to SEND a request (slowloris), but DO NOT
	# bound the response/stream: the MCP transport holds a long-lived
	# text/event-stream GET open, and a write/idle timeout here would close it
	# ("SSE stream disconnected: Premature close"). mcp has its own rate limiter.
	servers {
		timeouts {
			read_body 10s
			read_header 5s
		}
	}
}

# Shared path-split + edge hardening, imported by both edges below.
(brain_split) {
	# Strip sensitive material from access logs: query strings (defense in
	# depth), the legacy X-Brain-Key header, the bearer Authorization header,
	# and cookies (session/CSRF).
	log {
		output stdout
		format filter {
			wrap json
			fields {
				request>uri regexp "[?].*" ""
				request>headers>X-Brain-Key delete
				request>headers>Authorization delete
				request>headers>Cookie delete
			}
		}
	}

	# Don't advertise the stack to scanners.
	header -Server

	# Cap request bodies. OAuth POSTs are KiB-scale; MCP JSON-RPC fits under
	# 1 MiB. Larger uploads are an abuse signal.
	#
	# The matcher is load-bearing, NOT decoration: `request_body` sorts ahead of
	# `handle` in Caddy's directive order, so an unmatched site-level cap wraps
	# EVERY request in a 1MB MaxBytesReader — including the photo intake below,
	# whose own 13MB cap would then be the inner (never-reached) reader. Exclude
	# /capture/image here so its carve-out is the only cap on that path.
	@capped not path /capture/image
	request_body @capped {
		max_size 1MB
	}

	# ...except the app's photo intake (#42), which carries a full-resolution
	# camera image. Kept slightly above the app's own ceiling
	# (settings.MAX_IMAGE_UPLOAD_BYTES, default 12MB) so the JSON 413 comes from
	# Django — which knows the limit and can say so — rather than a bare Caddy
	# 413. Raising this without raising MAX_IMAGE_UPLOAD_BYTES changes nothing:
	# Django still rejects on `.size` before any decode.
	handle /capture/image {
		request_body {
			max_size 13MB
		}
		reverse_proxy web:8000 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto https
		}
	}

	# /mcp + RS metadata -> Python MCP service. FastMCP's RemoteAuthProvider
	# serves the RFC 9728 protected-resource metadata.
	#
	# FastMCP mounts the transport at /mcp/ (trailing slash) and 307-redirects a
	# bare /mcp to it. Over the Funnel that redirect downgrades to http://…:80
	# (the upstream can't see the external scheme), which isn't served — breaking
	# clients configured with the slash-less URL. Rewrite the exact bare path
	# to the canonical one so the client
	# sees no redirect, and forward X-Forwarded-Proto=https so any absolute URL
	# the app builds stays https.
	handle /mcp* {
		@bare path /mcp
		rewrite @bare /mcp/
		reverse_proxy mcp:8000 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto https
		}
	}
	handle /.well-known/oauth-protected-resource* {
		reverse_proxy mcp:8000 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto https
		}
	}

	# Everything else -> Django (/, /oauth/*, AS metadata, /accounts, /admin).
	# Force X-Forwarded-Proto=https: the external scheme is always https (TLS at
	# the tailscale edge or Caddy's own TLS), even when this hop is plain http.
	handle {
		reverse_proxy web:8000 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto https
		}
	}
}

# Tailnet edge: plain http behind the tailscale TLS terminator (no auto-https
# redirect, which would loop). serve.json roots "/" here.
:80 {
	import brain_split
}

# Local-TLS edge: `tls internal` self-signs for localhost / IPs (dev). A real
# public hostname would go to ACME automatically, but prod doesn't use this
# edge — the production host's public reach is Tailscale Funnel, not Caddy ACME.
{$BRAIN_HOSTNAME:localhost} {
	tls internal
	import brain_split
}

# Attachment reads (#42): minio's S3 API, on its own listener at the ROOT path.
#
# Root-mounted deliberately. A tidier-looking `handle_path /attachments/*` on the
# main edge does NOT work: SigV4 signs the request path, so stripping a prefix
# invalidates every presigned URL and minio answers 403 SignatureDoesNotMatch.
# Keeping minio at "/" means the path boto3 signed is the path minio receives.
#
# This listener is tailnet-only. tailscale/serve.json publishes :443 (and
# Funnel) -> caddy:80; it does NOT publish :9000, so attachments never leave the
# tailnet. Authorization is the presigned URL itself: a short-TTL bearer minted
# only after can_viewer_read passed (brain/services/reads.py).
:9000 {
	log {
		output stdout
		format filter {
			wrap json
			fields {
				# The query string IS the credential here — never log it.
				request>uri regexp "[?].*" ""
				request>headers>Authorization delete
				request>headers>Cookie delete
			}
		}
	}

	header -Server

	# GET/HEAD only: uploads go through the app (POST /capture/image), which
	# owns auth, the size ceiling, and the decode check. Nothing should be able
	# to write to the bucket through this door.
	@writes not method GET HEAD OPTIONS
	respond @writes "method not allowed" 405

	reverse_proxy minio:9000 {
		header_up X-Real-IP {remote_host}
	}
}
