# Mind Grapes — DEV stack environment (epic #61, slice #62).
#
# Copy to .env.dev (gitignored) before bringing up the dev stack:
#   cp .env.dev.example .env.dev
#   docker compose -f docker-compose.dev.yml up
#
# These are DEV-ONLY, non-secret placeholders — safe to commit as an example.
# The database name/credentials/ports and the live/dev isolation live in
# docker-compose.dev.yml as hardcoded literals, NOT here, so this file can
# never point the dev stack at live data.

# ─── Django (web service) ──────────────────────────────────────────────
SECRET_KEY=dev-secret-key-not-for-production
DEBUG=True

# ─── MCP (mcp service) ─────────────────────────────────────────────────
# Embeddings/extraction key. Leave blank for the walking skeleton (only
# needed once you start capturing); set a real key to exercise writes.
OPENROUTER_API_KEY=
# Legacy x-brain-key gate, used because AUTH_REQUIRE_OAUTH=false in dev.
MCP_ACCESS_KEY=dev
# Dev runs the legacy key path by default. With a valid bearer token Node
# still authenticates the call (shim mode); set true to require OAuth.
AUTH_REQUIRE_OAUTH=false

# ─── OAuth AS (Slice 3.1, #73): Django signs, Node validates via JWKS ───
# Shared by both the web (signer) and mcp (validator) services — they read
# this same .env.dev, so OAUTH_ISSUER/OAUTH_AUDIENCE stay in lockstep.
OAUTH_ISSUER=http://localhost:8080
OAUTH_AUDIENCE=brain
# Node fetches Django's JWKS internally (container-to-container; not via Caddy).
OAUTH_JWKS_URL=http://web:8000/oauth/jwks.json
# Ed25519 private key (PKCS8 PEM) used by Django to sign access tokens.
# Generate once and paste here (single line with \n separators is fine):
#   docker compose -f docker-compose.dev.yml run --rm web python manage.py gen_jwt_key
# Leave blank to skip signing (the JWKS endpoint 500s until it is set).
OAUTH_JWT_PRIVATE_KEY=
# The MCP endpoint a member pastes into Claude, shown on the /connect page
# (Slice 3.4, #76). Dev points at the local MCP service through Caddy.
BRAIN_MCP_URL=http://localhost:8080/mcp
