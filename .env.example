# Mind Grapes — environment configuration
#
# The same file works for local dev and production; the difference is which
# variables you set in `.env`. The blocks below are grouped: required
# (always), production-only, OAuth, and local overrides.
#
# Never commit `.env` to git.

# ─── Postgres ──────────────────────────────────────────────────────────
POSTGRES_USER=openbrain
POSTGRES_PASSWORD=replace-me-with-something-strong
POSTGRES_DB=openbrain

# ─── OpenRouter (embeddings + metadata extraction) ─────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Django web service ────────────────────────────────────────────────
# Django secret key (50+ random chars). REQUIRED: the web service runs
# config.settings.production, which refuses to boot on a missing, empty, or
# django-insecure-* key. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
# Hosts Django will answer for. Include your public hostname + service DNS.
#ALLOWED_HOSTS=brain.example.com,localhost,127.0.0.1,web
# Origins trusted for POSTs (OAuth authorize + passkey enroll) over HTTPS.
#CSRF_TRUSTED_ORIGINS=https://brain.example.com
# TLS is terminated at the edge (Tailscale or Caddy); internal container hops
# are plain http (including the healthcheck), so disable Django's
# http->https redirect when fronted by a TLS terminator.
#SECURE_SSL_REDIRECT=false
# HTTP Strict-Transport-Security max-age in seconds (0 disables). Leave unset
# locally so the self-signed dev cert doesn't pin a long policy in the
# browser. In prod (TLS at the edge):
#SECURE_HSTS_SECONDS=15552000
# Enrollment-link email. Point at a real SMTP relay in prod.
#DEFAULT_FROM_EMAIL=Mind Grapes <noreply@example.com>
#EMAIL_HOST=
#EMAIL_PORT=587

# ─── OAuth 2.1 (#41, #74, #95) ─────────────────────────────────────────
# Django is the authorization server; the MCP service is a pure resource
# server that validates Django-issued EdDSA access tokens OFFLINE against
# the published JWKS. Dynamic Client Registration (/oauth/register) is open
# by design and household-constrained — see #79 for the hardening discussion.
#
# Public-facing https URL of this server (no trailing slash). Local dev with
# Caddy: https://localhost. Prod: your public hostname — e.g. a Tailscale
# Funnel host, https://<machine>.<tailnet>.ts.net.
OAUTH_ISSUER=https://localhost
# Audience claim the MCP resource server enforces (must match what Django signs).
OAUTH_AUDIENCE=brain
# Ed25519 signing key (PKCS8 PEM), Django-only. Generate with:
#   python manage.py gen_jwt_key
OAUTH_JWT_PRIVATE_KEY=
# Where the MCP service fetches Django's JWKS (internal service URL; bypasses
# the edge).
#OAUTH_JWKS_URL=http://web:8000/oauth/jwks.json
# Access-token lifetime in seconds (default 600).
#OAUTH_ACCESS_TTL_SECONDS=600

# The MCP endpoint a member pastes into Claude, shown on the Django /connect
# page (#76). Dev default is http://localhost:8080/mcp; set your public https
# URL in prod.
#BRAIN_MCP_URL=https://brain.example.com/mcp

# ─── Edge hostname ─────────────────────────────────────────────────────
# Hostname Caddy serves on. Local dev: leave unset (defaults to localhost,
# self-signed cert via `tls internal`). Behind the Tailscale sidecar: also
# leave at localhost — Tailscale terminates TLS (tailnet + `*.ts.net` Funnel)
# and forwards plain HTTP to Caddy's :80 edge, so Caddy doesn't fetch a cert.
#BRAIN_HOSTNAME=localhost

# ─── Tailscale sidecar (opt-in via compose profile) ────────────────────
# `docker compose --profile tailscale up` brings up the tailscale container,
# used as the production edge (tailnet + `*.ts.net` Funnel) or a dev-loop
# tunnel. One-time auth key from
# https://login.tailscale.com/admin/settings/keys (reusable=false, ephemeral=false)
TS_AUTHKEY=tskey-auth-...
TS_HOSTNAME=openbrain-mcp

# ─── Soft privacy (#66) ────────────────────────────────────────────────
# Every captured experience is stamped with a household account_id and an
# owner. The owner is the authenticated member's OAuth sub; where no sub is
# available it falls back to DEFAULT_OWNER. Defaults suit a single-household
# deployment — override for a differently-named household or primary owner.
#HOUSEHOLD_ACCOUNT_ID=household
#DEFAULT_OWNER=owner

# ─── Attachments / object storage (#42) ────────────────────────────────
# Image blobs live in the minio service (docker-compose.yml), not Postgres.
# BLOBSTORE_BACKEND and S3_ENDPOINT are set inline by compose (topology, not
# secrets); everything below comes from here.
#
# Credentials for the bucket. These ARE secrets — generate, don't copy:
#   openssl rand -hex 16
# minio boots with these as its root user/password, so changing them after the
# first boot needs a minio-side user change, not just an .env edit.
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=brain-attachments
S3_REGION=us-east-1
#
# CRITICAL: the address the CLIENT fetches presigned URLs from — the tailnet
# host, NOT the in-network http://minio:9000. SigV4 signs the Host header, so a
# URL signed for the internal address 403s (SignatureDoesNotMatch) the moment an
# app on the tailnet fetches it. Caddy serves minio on :9000 at the root path
# (see caddy/Caddyfile); no path prefix, because stripping one breaks the
# signature the same way.
#   S3_PUBLIC_ENDPOINT=http://<machine>.<tailnet>.ts.net:9000
S3_PUBLIC_ENDPOINT=
#
# REQUIRED. Which interface Caddy's attachment listener binds. There is no
# compose default on purpose: 0.0.0.0 publishes minio's S3 API on EVERY host
# interface, and not-Funnel is not the same as not-public — tailscale/serve.json
# declining to publish :9000 says nothing about the host's own NICs. On the
# public-host recipe the box sits directly on the internet, and Docker writes
# published-port rules into the DOCKER chain ahead of a ufw INPUT policy, so
# "open only 80+443" does not close :9000. Reach for minio is half the read
# authorization story — a leaked presigned URL should only be redeemable from
# the tailnet, not globally.
#   tailnet clients:  ATTACHMENTS_BIND_ADDR=<tailscale ip -4>
#   same-host only:   ATTACHMENTS_BIND_ADDR=127.0.0.1
ATTACHMENTS_BIND_ADDR=
#
# Hard ceiling on a POST /capture/image upload, in bytes (default 12MB).
# Rejected on Content-Length BEFORE any decode. Raising this also needs the
# matching cap raised in caddy/Caddyfile.
#MAX_IMAGE_UPLOAD_BYTES=12582912

# ─── Encrypted offsite backups (#90) ───────────────────────────────────
# backup.sh ships each pg_dump to a restic repository (e.g. Backblaze B2).
# Leave RESTIC_REPOSITORY unset for local-only dumps; set all four for prod.
#
# restic repo on B2:  b2:<bucket-name>:<path-prefix>
#RESTIC_REPOSITORY=b2:my-brain-backups:prod
#
# CROWN JEWEL — losing this makes every backup permanently unrecoverable.
# Store it OFFLINE (password manager + a printed copy), separate from the box.
# Generate with: openssl rand -base64 32
#RESTIC_PASSWORD=
#
# Backblaze B2 application key scoped to the one bucket above.
#B2_ACCOUNT_ID=
#B2_ACCOUNT_KEY=
#
# Retention (optional; restic forget defaults shown).
#RESTIC_KEEP_DAILY=14
#RESTIC_KEEP_WEEKLY=8
#RESTIC_KEEP_MONTHLY=12

# ─── Local overrides ───────────────────────────────────────────────────
# Bind address. 127.0.0.1 (default) is correct when fronted by Caddy or
# Tailscale on the same host. Set 0.0.0.0 only for non-sidecar deploys.
BIND_ADDR=127.0.0.1
